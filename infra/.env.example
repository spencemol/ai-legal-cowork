# ============================================================
# Legal AI Tool — Environment Variables Reference
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# ── Shared (used by both api and agents) ────────────────────
# Minimum 32 characters, random string.  Both services MUST
# share the exact same value so JWTs issued by the Node API
# can be validated by the Python agents backend.
JWT_SECRET=change-me-in-production-use-32-char-min

# ── Postgres ────────────────────────────────────────────────
POSTGRES_USER=legal_user
POSTGRES_PASSWORD=legal_password
POSTGRES_DB=legal_ai
POSTGRES_PORT=5432

# ── MongoDB ─────────────────────────────────────────────────
MONGO_USER=legal_user
MONGO_PASSWORD=legal_password
MONGO_DB=legal_ai_checkpoints
MONGO_PORT=27017

# ── Node REST API ───────────────────────────────────────────
API_PORT=3000
NODE_ENV=production
# Constructed automatically in docker-compose from the Postgres vars above:
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ── Python Agents Backend ───────────────────────────────────
AGENTS_PORT=8000
# Constructed automatically in docker-compose:
# MONGO_URI=mongodb://${MONGO_USER}:${MONGO_PASSWORD}@mongodb:27017/${MONGO_DB}?authSource=admin

# Pinecone vector database
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX=legal-docs

# Anthropic Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# LLM tuning (optional — defaults shown)
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# Sentence-Transformers embedding model (local, no API key required)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── LangSmith Observability (optional) ─────────────────────
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=legal-ai-tool

# ── Desktop App (Tauri/Vite) ────────────────────────────────
# Set in desktop/.env.local (not tracked by docker-compose)
VITE_API_URL=http://localhost:3000
VITE_AGENTS_URL=http://localhost:8000

# ── Seed Script ─────────────────────────────────────────────
# Used by infra/scripts/seed.py
SEED_API_URL=http://localhost:3000
SEED_AGENTS_URL=http://localhost:8000
SEED_ADMIN_EMAIL=admin@firm.com
SEED_ADMIN_PASSWORD=SeedPass123!
SEED_ATTORNEY_EMAIL=attorney@firm.com
SEED_ATTORNEY_PASSWORD=SeedPass456!
